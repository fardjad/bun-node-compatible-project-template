{
  "name": "changeme",
  "version": "0.0.4",
  "description": "TODO: describe package",
  "type": "module",
  "license": "MIT",
  "author": "Fardjad Davari <public@fardjad.com>",
  "homepage": "https://github.com/fardjad/changeme#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fardjad/changeme.git"
  },
  "bugs": {
    "url": "https://github.com/fardjad/changeme/issues"
  },
  "keywords": [
    "cli"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "changeme": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "bun run clean && bun run build:esm && bun run build:cjs && bun run build:cli && bun run build:types",
    "build:esm": "bun build src/index.ts --target=node --format=esm --outfile dist/index.mjs",
    "build:cjs": "bun build src/index.ts --target=node --format=cjs --outfile dist/index.cjs",
    "build:cli": "bun build src/cli.ts --target=node --format=esm --outfile dist/cli.mjs",
    "build:types": "tsc -p tsconfig.build.json",
    "check": "biome check . && dprint check",
    "clean": "bun -e 'await Bun.$`rm -rf dist`'",
    "fix": "biome check --write . && dprint fmt",
    "rename-template": "bun run scripts/rename-template.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@dprint/markdown": "^0.21.1",
    "@types/bun": "1.3.13",
    "dprint": "^0.54.0",
    "dprint-plugin-yaml": "^0.6.0",
    "typescript": "6.0.3"
  }
}
